# Maintainer: GhostPad Team <ghostpad@example.com>
pkgname=ghostpad
pkgver=0.1.0
pkgrel=1
pkgdesc="A lightweight, Windows 11-style text editor for KDE Plasma"
arch=('x86_64')
url="https://github.com/ghostpad/ghostpad"
license=('MIT')
depends=(
    'qt6-base'
    'qt6-declarative'
    'kirigami'
    'kwindowsystem'
    'hicolor-icon-theme'
)
makedepends=(
    'rust'
    'cargo'
    'cmake'
    'extra-cmake-modules'
    'clang'
    'qt6-tools'
    'corrosion'
)
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    export RUSTFLAGS="-C target-cpu=native"
    cargo build --release --target "$CARCH-unknown-linux-gnu"
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Binary
    install -Dm755 "target/$CARCH-unknown-linux-gnu/release/ghostpad-app" \
        "$pkgdir/usr/bin/ghostpad"

    # QML files
    install -dm755 "$pkgdir/usr/share/ghostpad/qml"
    cp -r app/qml/* "$pkgdir/usr/share/ghostpad/qml/"

    # Desktop entry
    install -Dm644 "packaging/dev.ghostpad.GhostPad.desktop" \
        "$pkgdir/usr/share/applications/dev.ghostpad.GhostPad.desktop"

    # AppStream metadata
    install -Dm644 "packaging/dev.ghostpad.GhostPad.metainfo.xml" \
        "$pkgdir/usr/share/metainfo/dev.ghostpad.GhostPad.metainfo.xml"

    # Icon
    install -Dm644 "assets/icons/ghostpad.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/dev.ghostpad.GhostPad.png"

    # License
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
